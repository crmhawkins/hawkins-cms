      "content": [
        { "type": "Hero", "props": { "id": "hero-a", "title": "Qué es Cuaderno", "subtitle": "Una revista pequeña, hecha con tiempo", "kicker": "", "backgroundImage": "https://images.unsplash.com/photo-1432888622747-4eb9a8efeb07?w=1200&q=80", "align": "center", "height": "medium", "overlay": 0.4, "ctaLabel": "", "ctaUrl": "" } },
        { "type": "TextBlock", "props": { "id": "tb-a", "heading": "Nuestra propuesta", "body": "Cuaderno es una revista digital independiente publicada desde 2021. Escribimos sobre libros, ideas y tecnología, pero siempre desde una perspectiva lenta y personal. No publicamos para ganar clics. Publicamos para que merezca la pena leer.", "align": "center", "maxWidth": "narrow", "background": "white" } },
