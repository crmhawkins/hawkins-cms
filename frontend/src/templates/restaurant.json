        { "type": "TextBlock", "props": { "id": "tb-1", "heading": "Un restaurante pequeño con ambición", "body": "Trabajamos con pescados de lonja, verduras del huerto familiar y carne de ganadería regenerativa. Carta corta que cambia cada quince días.", "align": "center", "maxWidth": "medium", "background": "white" } },
