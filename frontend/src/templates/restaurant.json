        { "type": "ImageText", "props": { "id": "it-1", "imageUrl": "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=1200&q=80", "imageAlt": "Cocina", "heading": "Cocina abierta, equipo pequeño", "body": "Seis personas en sala y cocina, todos con nombre y apellidos. Nos gusta que nos conozcas. Pasa por la cocina cuando quieras saludar.", "ctaLabel": "Conócenos", "ctaUrl": "/about", "imageSide": "right", "background": "light" } },
        { "type": "Testimonials", "props": { "id": "tst-1", "heading": "Opiniones recientes", "items": [ { "quote": "Uno de los mejores restaurantes de barrio de Madrid. Producto de diez y precio justo.", "author": "El Comidista", "role": "Crítica gastronómica", "photo": "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=600&q=80" }, { "quote": "Fui con mi madre y ahora quiere ir todas las semanas. Cocina honesta y buena.", "author": "Javier T.", "role": "Google Reviews", "photo": "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=600&q=80" } ], "layout": "grid", "background": "white" } },
