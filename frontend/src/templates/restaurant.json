        { "type": "TextBlock", "props": { "id": "tb-m1", "heading": "Entrantes", "body": "Tomate del huerto en tres texturas · 9€\\nAnchoas del Cantábrico con mantequilla · 14€\\nVieira a la brasa con puerros · 16€\\nCroquetas de cocido (4 uds) · 8€", "align": "left", "maxWidth": "medium", "background": "white" } },
        { "type": "TextBlock", "props": { "id": "tb-m2", "heading": "Principales", "body": "Merluza a la brasa con pil-pil de temporada · 22€\\nCordero lechal glaseado con hinojo · 24€\\nCanelón de rustido de ternera · 18€\\nArroz meloso de codorniz · 19€", "align": "left", "maxWidth": "medium", "background": "light" } },
