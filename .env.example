# ══════════════════════════════════════════════════════════════
# hawkins-cms — variables de entorno
# Copia este fichero a .env y rellena los valores.
# En Coolify se introducen desde "Environment Variables".
# ══════════════════════════════════════════════════════════════

# ─── Dominio público del sitio ──────────────────────────────
# Ejemplo producción:   https://sanzahra.com
# Ejemplo local:        http://localhost:3000
PUBLIC_URL=http://localhost:3000

# ─── MariaDB ────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=cambia_esto_root
MARIADB_DATABASE=hawkins_cms
MARIADB_USER=hawkins
MARIADB_PASSWORD=cambia_esto_password

# ─── Directus (panel admin + API) ───────────────────────────
# Genera valores aleatorios fuertes. Ejemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DIRECTUS_KEY=cambia_esto_random_32_chars
DIRECTUS_SECRET=cambia_esto_random_32_chars
DIRECTUS_ADMIN_EMAIL=admin@tudominio.com
DIRECTUS_ADMIN_PASSWORD=cambia_esto_admin_pass
# Token estático para que Next.js hable con Directus (crea uno en admin tras primer login)
DIRECTUS_STATIC_TOKEN=

# ─── MinIO (almacenamiento de imágenes S3-compatible) ───────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=cambia_esto_minio_pass
MINIO_BUCKET=media

# ─── Email (opcional, para formularios y notificaciones) ────
EMAIL_FROM=noreply@tudominio.com
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_SECURE=false

# ─── Traducción automática ──────────────────────────────────
# DeepL Free API: https://www.deepl.com/pro-api (500k chars gratis/mes)
# Si no la configuras, usará LibreTranslate self-hosted como fallback.
DEEPL_API_KEY=

# Idiomas que LibreTranslate descargará al arrancar (separados por coma)
# Ligero: solo los que uses. Idiomas disponibles:
# ar, az, ca, cs, da, de, el, en, eo, es, fa, fi, fr, ga, he, hi, hu, id, it,
# ja, ko, lt, lv, ms, nb, nl, pl, pt, ro, ru, sk, sl, sq, sv, th, tl, tr, uk, vi, zh, zt
LT_LANGUAGES=en,es,fr,de,pt,it,ca
